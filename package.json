{
  "name": "medicine-wheel",
  "version": "1.0.0",
  "private": true,
  "description": "Medicine Wheel — Interactive visual layer for Indigenous relational research with Four Directions, ceremonies, and narrative arcs",
  "scripts": {
    "build:packages": "for dir in src/ontology-core src/ceremony-protocol src/narrative-engine src/graph-viz src/relational-query src/prompt-decomposition src/ui-components src/data-store src/session-reader; do (cd $dir && npx tsc --skipLibCheck 2>/dev/null || true); done",
    "predev": "npm run build:packages",
    "prebuild": "npm run build:packages",
    "dev": "next dev --turbopack -p 3940",
    "build": "next build",
    "start": "next start -p 3940",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "next-themes": "^0.4.6",
    "sonner": "^1.7.0",
    "lucide-react": "^0.475.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.2",
    "recharts": "^2.15.4",
    "medicine-wheel-ontology-core": "file:./src/ontology-core",
    "medicine-wheel-ceremony-protocol": "file:./src/ceremony-protocol",
    "medicine-wheel-narrative-engine": "file:./src/narrative-engine",
    "medicine-wheel-graph-viz": "file:./src/graph-viz",
    "medicine-wheel-relational-query": "file:./src/relational-query",
    "medicine-wheel-prompt-decomposition": "file:./src/prompt-decomposition",
    "medicine-wheel-ui-components": "file:./src/ui-components",
    "medicine-wheel-data-store": "file:./src/data-store",
    "medicine-wheel-session-reader": "file:./src/session-reader"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0"
  }
}
