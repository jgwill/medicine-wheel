{
  "name": "medicine-wheel-ceremony-protocol",
  "version": "0.2.0",
  "description": "Ceremony lifecycle protocol for Medicine Wheel — manages ceremony state, phase transitions, governance enforcement, and ceremonial review workflows",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "medicine-wheel-ontology-core": "^0.2.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "keywords": [
    "medicine-wheel",
    "ceremony",
    "governance",
    "indigenous",
    "ocap"
  ],
  "license": "MIT"
}
