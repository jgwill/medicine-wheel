{
  "name": "medicine-wheel-prompt-decomposition",
  "version": "0.1.2",
  "description": "Prompt Decomposition Engine for the Medicine Wheel Developer Suite — ontology-enriched intent extraction, relational dependency mapping, and ceremony-aware action stacking",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "browser": "./dist/index.browser.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./browser": {
      "import": "./dist/index.browser.js",
      "types": "./dist/index.browser.d.ts",
      "require": "./dist/index.browser.js",
      "default": "./dist/index.browser.js"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts",
      "require": "./dist/types.js",
      "default": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "medicine-wheel",
    "prompt-decomposition",
    "pde",
    "intent-extraction",
    "four-directions",
    "ontology",
    "relational",
    "ceremony",
    "indigenous-research"
  ],
  "author": "IAIP Collaborative - Shawinigan, QC",
  "license": "MIT",
  "dependencies": {
    "medicine-wheel-ontology-core": "^0.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  }
}
