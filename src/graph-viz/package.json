{
  "name": "@medicine-wheel/graph-viz",
  "version": "0.4.12",
  "description": "Medicine Wheel graph visualization — circular layout with four-direction node positioning, ceremony-aware edges, and OCAP® indicators",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./interactive": {
      "import": "./dist/interactive/index.js",
      "types": "./dist/interactive/index.d.ts",
      "require": "./dist/interactive/index.js",
      "default": "./dist/interactive/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "medicine-wheel",
    "graph-visualization",
    "d3",
    "react",
    "four-directions",
    "indigenous-research",
    "circular-layout"
  ],
  "author": "IAIP Collaborative - Shawinigan, QC",
  "license": "MIT",
  "dependencies": {
    "@medicine-wheel/ontology-core": "^0.4.12"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "@xyflow/react": ">=12.0.0"
  },
  "peerDependenciesMeta": {
    "@xyflow/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@xyflow/react": "^12.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.3.0"
  }
}
