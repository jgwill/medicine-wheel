{
  "name": "medicine-wheel-fire-keeper",
  "version": "0.1.0",
  "description": "Fire Keeper coordination agent for Medicine Wheel — tends the ceremony fire, ensures relational integrity through gating conditions, and maintains Wilson alignment as an active agent",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "medicine-wheel-ontology-core": "^0.1.3",
    "medicine-wheel-ceremony-protocol": "^0.1.3"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "keywords": [
    "medicine-wheel",
    "fire-keeper",
    "ceremony",
    "governance",
    "indigenous",
    "wilson",
    "relational-accountability"
  ],
  "license": "MIT"
}
