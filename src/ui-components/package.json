{
  "name": "medicine-wheel-ui-components",
  "version": "0.1.0",
  "description": "React UI components for the Medicine Wheel Developer Suite — direction cards, beat timelines, node inspectors",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
