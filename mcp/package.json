{
  "name": "@medicine-wheel/mcp",
  "version": "4.2.8",
  "description": "Medicine Wheel MCP Server — Integrated Indigenous Paradigm Research Framework",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist/**/*",
    "package.json",
    "tsconfig.json"
  ],
  "bin": {
    "medicine-wheel-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"try { require('fs').chmodSync('dist/index.js', 0o755); } catch (error) { console.warn('[mcp] chmod skipped (non-fatal):', error.message); }\"",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "mcp",
    "medicine-wheel",
    "indigenous-research",
    "four-directions",
    "ocap",
    "data-sovereignty",
    "shawn-wilson",
    "two-eyed-seeing",
    "ceremony"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@medicine-wheel/ontology-core": "^0.2.8",
    "@medicine-wheel/ceremony-protocol": "^0.2.8",
    "@medicine-wheel/community-review": "^0.2.8",
    "@medicine-wheel/consent-lifecycle": "^0.2.8",
    "@medicine-wheel/fire-keeper": "^0.2.8",
    "@medicine-wheel/graph-viz": "^0.2.8",
    "@medicine-wheel/importance-unit": "^0.2.8",
    "@medicine-wheel/narrative-engine": "^0.2.8",
    "@medicine-wheel/prompt-decomposition": "^0.2.8",
    "@medicine-wheel/relational-index": "^0.2.8",
    "@medicine-wheel/relational-query": "^0.2.8",
    "@medicine-wheel/session-reader": "^0.2.8",
    "@medicine-wheel/transformation-tracker": "^0.2.8",
    "@medicine-wheel/ui-components": "^0.2.8"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  }
}
